{
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "outputStyle": "explanatory",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Bash(*)",
      "WebFetch",
      "WebSearch",
      "NotebookEdit"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -r *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git push)",
      "Bash(git push *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(git rebase)",
      "Bash(git rebase *)",
      "Bash(git stash drop)",
      "Bash(git stash drop *)",
      "Bash(git stash clear)",
      "Bash(git checkout .)",
      "Bash(git restore .)",
      "Bash(killall *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)"
    ],
    "deny": []
  }
}
